    -- Form Variables
  -- Current Element
  member .element     is DBREF

  -- Current attribute query shown
  member .current     is DBREF

  -- Current Header State
  member .headerState is ARRAY

  -- Locked
  member .tracking    is BOOLEAN

  -- Header
  member .header      is STRING

  -- Data Table
  member .dataTable   is ARRAY

  -- Ship Reference Grid Set
  member .shipGrid    is BOOLEAN

  -- Register from
  !!appFormCntrl.registerForm(!this) 
exit
-----------------------Methods-------------------------
define method .myDesignMacro()

  -- Initialise Variables
  !this.tracking    = true
  !this.lock.val    = !this.tracking

  -- Check if distance format has been declared
  if(undefined(!!distanceFmt)) then
    !!comDefineGlobal(object COMFORMATS())
  endif


endmethod

--------------------Init() Method----------------------
define method .init()

---- Initialize headTailOpt
!dtext[1] = |Head to First|
!dtext[2] = |Head to ID@|
!dtext[3] = |Head to Branch Tail|
!dtext[4] = |Head to Branch Head|
!dtext[5] = |Head to Multiway|
!dtext[6] = |Tail to Last|
!dtext[7] = |Tail to ID@|
!dtext[8] = |Tail to Branch Tail|
!dtext[9] = |Tail to Branch Head|
!dtext[10] = |Tail to Multiway|

!rtext[1] = |BRAN CONN PH TO FIRST MEM|
!rtext[2] = |BRAN CONN PH TO ID@|
!rtext[3] = |BRAN CONN PH TO PT OF ID BRAN @|
!rtext[4] = |BRAN CONN PH TO PH OF ID BRAN @|
!rtext[5] = |BRAN CONN PH TO IDP@|
!rtext[6] = |BRAN CONN PT TO LAST MEM|
!rtext[7] = |BRAN CONN PT TO ID@|
!rtext[8] = |BRAN CONN PT TO PT OF ID BRAN @|
!rtext[9] = |BRAN CONN PT TO PH OF ID BRAN @|
!rtext[10] = |BRAN CONN PT TO IDP@|

!this.headTailOpt.dtext = !dtext
!this.headTailOpt.rtext = !rtext

---- Initialize MODE (Forward Backward)
--for some reason if I use PML2 !MODE = MODE it doesn't work
VAR !MODE  MODE
if !MODE EQ |Forwards| then
	!this.forwBackwFrame.val = 1
elseif !MODE EQ |Backwards| then
	!this.forwBackwFrame.val = 2
endif

---- Initialize spoolFrame
!this.spoolFrame.val = 1

---- Initialize planViewFrame
!this.planViewFrame.val = 1
!this.viewU.active = FALSE
!this.viewD.active = FALSE

---- Unfold piping TOOLS
--!this.pipingFoldup.expanded = FALSE


endmethod

------------------------------------------------------------------------

define method .lock()

  -- Set tracking flag
  !this.tracking  = !this.lock.val

  -- If tracking and at a different element
  if(!this.tracking and !!ce ne !this.element) then
    !this.query(!!ce)
  endif

endmethod
------------------------------------------------------------------------

define method .query()

  -- Handle delete element
  if(badRef(!this.element)) then
    !this.element = object DBREF()
  endif

  -- Handle delete element
  if(badRef(!this.current)) then
    !this.current = object DBREF()
  endif

  -- Display query information
  if(!this.tracking or !this.element.unset() or !this.element ne !this.current) then
    !this.query(!!ce)
  endif

endmethod
------------------------------------------------------------------------

define method .query(!element is DBREF)
  -- Initialise Variables
  !this.element   = !element
  
  if TYPE OF OWNER EQ |PIPE| OR TYPE OF OWNER EQ |BRAN| then
	  !PIPE = PIPE
	  !this.attributes.setHeadings(!!CE.NAMESQ + ' | LineNo: $!PIPE.NAMN')
  else
	!this.attributes.setHeadings(!!CE.NAMESQ)
  endif
  handle any
     return
  endhandle

  !DVAL = ARRAY()
  !this.attributes.dtext = !DVAL
  if TYPE OF OWNER EQ |BRAN| AND TYPE NE |PTAP| THEN
	
	!DTXR = DTXR
	handle any
		!DTXR = ''
	endhandle
	!MTXX = MTXX
	handle any
		!MTXX = ''
	endhandle
	if !DTXR EQ '' AND !MTXX EQ '' then
		!this.attributes.ADD(|No Description!!|)
	else
		!this.attributes.ADD(|$!DTXR| + ' ' + |$!MTXX|)
	endif

	!P1BOR = P1 BORE
	handle (2,201)
		!P1BOR = 'Unset'
	endhandle
	!P2BOR = P2 BORE
	handle (2,201)
		!P2BOR = 'Unset'
	endhandle
	!P3BOR = P3 BORE
	handle (2,201)
		!P3BOR = 'Unset'
	endhandle
	!P4BOR = P4 BORE
	handle (2,201)
		!P4BOR = 'Unset'
	endhandle

	if !P4BOR.STRING() EQ 'Unset' then
		if !P3BOR.STRING() EQ 'Unset' then
			if !P2BOR.STRING() EQ 'Unset' OR !P1BOR EQ !P2BOR then
				!this.attributes.ADD('Size: ' + !P1BOR.STRING())
			else 
				!this.attributes.ADD('Size: ' + !P1BOR.STRING() + ' x ' + !P2BOR.STRING())
			endif
		elseif  !P1BOR EQ !P2BOR then
			!this.attributes.ADD('Size: ' + !P1BOR.STRING() + ' x ' + !P3BOR.STRING())
		else
			!this.attributes.ADD('Size: ' + !P1BOR.STRING() + ' x ' + !P2BOR.STRING() + ' x ' + !P3BOR.STRING())
		endif
	else
		!this.attributes.ADD('Size: ' + !P1BOR.STRING() + ' x ' + !P2BOR.STRING() + ' x ' + !P3BOR.STRING() + ' x ' + !P4BOR.STRING())
	endif
		
	!ATLE = ATLE
	!LTLE = LTLE
	!this.attributes.ADD('ATLE: ' + !ATLE.STRING(!!REALFMT) + 'mm LTLE: ' + !LTLE.STRING(!!REALFMT) + 'mm')

  elseif TYPE EQ |NOZZ| then
	!P1BOR = P1 BORE
	!P1CONN = P1 CONN
	!this.attributes.ADD('Nozzle: ' + DESC OF CATE OF CATREF OF SPREF)
	!this.attributes.ADD('Catref: ' + !!CE.CATREF.NAMN)
	!this.attributes.ADD('Size: ' + !P1BOR.STRING() + '  Height: ' + !!CE.HEI.STRING() + '  ConnType: ' + !P1CONN.STRING())
  endif

endmethod
-------------------------------------------------------
define method .inactiveButtonView(!select is REAL)
if !select EQ 1 then
	!this.viewU.active = FALSE
	--!this.viewU.BACKGROUND = 300
	!this.viewD.active = FALSE
elseif !select EQ 2 then
	!this.viewU.active = TRUE
	--!this.viewU.BACKGROUND = 'LightGold'
	!this.viewD.active = TRUE
endif
endmethod
-------------------Plan View Method--------------------
define method .planViewMethod(!select is STRING)
if !this.planViewFrame.val EQ 1 then
	if !select EQ |N| then
		!!gphViews.look(!!gph3Ddesign1.view,N90D)
	elseif !select EQ |S| then
		!!gphViews.look(!!gph3Ddesign1.view,S90D)
	elseif !select EQ |E| then
		!!gphViews.look(!!gph3Ddesign1.view,E90D)
	elseif !select EQ |W| then
		!!gphViews.look(!!gph3Ddesign1.view,W90D)
	elseif !select EQ |U| then
		!this.mainFrame.tag = 'Design Macro V 0.1 by Ehsan Rafat | | Nothing as Plan Up View!'
	elseif !select EQ |D| then
		!this.mainFrame.tag = 'Design Macro V 0.1 by Ehsan Rafat | | Nothing as Plan Down View!'
	endif
elseif !this.planViewFrame.val EQ 2 then
	!!gphViews.look(!!gph3Ddesign1.view,$!select)
elseif !this.planViewFrame.val EQ 3 then
	BY $!select $!this.moveCust.val WRT/*
endif

endmethod

-------------------Head Tail Method--------------------
define method .headTailMethod()

VAR !MODE MODE	
IF (!MODE EQ |Forwards|) THEN
	FORWARD
	$!this.headTailOpt
ELSEIF (!MODE EQ |Backwards|) THEN
	FORWARD
	$!this.headTailOpt
	BACKWARD
ENDIF

endmethod

---------------SPOOL / DIST / MOVE / BOP---------------
define method .spoolMethod(!value is REAL)

VAR !M MEM COUNT OF OWN
VAR !MODE MODE

!spoolMode = !this.spoolFrame.val
if $!spoolMode EQ 1 then
	IF (SEQ EQ 1 AND !MODE EQ |Forwards|) THEN
		POS PA DIST $!value FROM PH
	ELSEIF (SEQ EQ $!M AND !MODE EQ |Backwards|) THEN
		POS PL DIST $!value FROM PT
	ELSEIF (SEQ NE 1 AND !MODE EQ |Forwards|) THEN
		POS PA DIST $!value FROM PL OF PREV
	ELSEIF (SEQ NE $!M AND !MODE EQ |Backwards|) THEN
		POS PL DIST $!value FROM PA OF PREV
	ENDIF
elseif !spoolMode EQ 2 then
	DIST $!value
elseif !spoolMode EQ 3 then
	MOVE DIST $!value
elseif !spoolMode EQ 4 then	
	BOP $!value ONTO ID@
endif

endmethod

---------------------SBOP Method-----------------------
define method .sbopMethod()
LABEL /BEGIN
OWN
VAR !OWN TYPE

IF (|$!OWN| NEQ |BRAN|) THEN
   RETURN ERROR 1 |You are not at a piping component.|
ENDIF
SAM
!TYPE = TYPE OF CE

!REF = REF OF ID@
	!ABOP = ABOP OF $!REF
	!LBOP = LBOP OF $!REF

	!pos1 = !REF.pos.up
	!Ldir = !REF.ldir.wrt(worl)
	!Adir = !REF.Adir.wrt(worl)

		!LDIRU = MATCHW(STRING (!LDIR), '*U*')
		!ADIRU = MATCHW(STRING (!ADIR), '*U*')
		!LDIRD = MATCHW(STRING (!LDIR), '*D*')
		!ADIRD = MATCHW(STRING (!ADIR), '*D*')

	IF $!ADIRU EQ TRUE OR $!ADIRD EQ TRUE THEN
		!BOP = $!REF.LBOP
			ELSEIF $!LDIRU EQ TRUE OR $!LDIRD EQ TRUE THEN
			!BOP = $!REF.ABOP
			ELSE
		!BOP = $!REF.LBOP
	ENDIF

BOP ONTO U $!BOP.UP
LABEL /END
$.
endmethod

--------------------KT-Methods-------------------------
define method .ktMethod()
var !MODE MODE
if (!MODE EQ |Forwards|) then
	FORWARD THRO CE
	BACKWARD THRO CE
	FORWARD THRO CE
	BACKWARD THRO CE
	FORWARD THRO CE
	BACKWARD THRO CE
	FORWARD THRO CE
	BACKWARD THRO CE
	FORWARD THRO CE
	BACKWARD THRO CE
	FORWARD THRO CE
elseif (!MODE EQ |Backwards|) then
	FORWARD THRO CE
	BACKWARD THRO CE
	FORWARD THRO CE
	BACKWARD THRO CE
	FORWARD THRO CE
	BACKWARD THRO CE
	FORWARD THRO CE
	BACKWARD THRO CE
	FORWARD THRO CE
	BACKWARD THRO CE
	FORWARD THRO CE
	BACKWARD THRO CE
endif
endmethod

--------------Create Component Methods-----------------
define method .createComponent(!type is STRING)
var !REFE REFE
NEW $!type CHOOSE ALL

handle (61,162) (61,163) (61,164) (61,165)
	DELETE $!type
	$!REFE
   handle ANY
   endhandle
   return error
 endhandle
 
onerror return
var !SPREF SPREF

if(!SPREF eq |=0/0|) then
	DELETE $!type
	$!REFE
else
	CONN
endif
endmethod
