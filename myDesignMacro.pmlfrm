setup form !!myDesignMacro SIZE 45 35 dialog dock RIGHT
!this.formTitle = |My Design Macro|
!this.initcall = |!this.init()|
-----------------------------------------------------------------------------------
-- This Macro is made by Ehsan Rafat at 2026/04. This version is not for public use
-- and I mostly tried to rewrite and improve an old design macro using PML 2 for My
-- training purpose and personal use.
-----------------------------------------------------------------------------------

  -- Define tracking for relevant modules
  track    |PADDCE| call |!this.query()|
  track    |DESICE| call |!this.query()|
  track    |CATACE| call |!this.query()|
  track    |ISODCE| call |!this.query()|
  track    |SCHECE| call |!this.query()|
  track    |PROPCE| call |!this.query()|
  track    |MANUCE| call |!this.query()|
  track	   |SYSTCE| call |!this.query()|
  track	   |GLOBCE| call |!this.query()|

frame .mainFrame |Design Macro V 0.1 by Ehsan Rafat| at x 0 y 0 dock fill
-----------------Main Frame Tools----------------------
	frame .forwBackwFrame at xmin ymin - 0.2 width 46
	
		rToggle .forwTog |Forw| tagwid 4 at xmin ymin call |FORWARD|
		rToggle .backTog |Backw| tagwid 5 at xmax ymin call |BACKWARD|
		button .getButton |GETWORK| hei 1 at xmax + 1 ymin.backTog backg 98 tooltip 'Get Work' call |GETWORK|
		button .saveButton |SAVE| hei 1 at xmax ymin.getButton backg lightblue tooltip 'Save Work' call |SAVEWORK|
		button .unclaimButton |UNCLAIM| hei 1 at xmax ymin.getButton backg 67 tooltip 'Save & Unclaim All' call |SAVEWORK 
		unclaim ALL 
		savework|
		
		button .prevButton |<<| hei 1 at x 0 ymax backg 98 tooltip 'Previous Item' call |PRE|
		button .reselectButton |RESEL| hei 1 at xmax ymin backg 228 tooltip 'Reselect component (Choose All)' call |CHOO ALL|
		button .nextButton |>>| hei 1 at xmax ymin backg 98 tooltip 'Next Item' call |NEX|
		button .idButton |↗| hei 1 width 4 at xmax ymin backg lightblue tooltip 'ID@' call |ID@|
		button .zoomButton |ZOOM CE| hei 1 at xmax ymin backg wheat tooltip 'Zoom to Selection' call |!!zoomToPipeElement(!!ce)|
		button .centerButton |CENTR CE| hei 1 at xmax ymin backg 208 tooltip 'Centre on CE' call |!!gphViews.rotate(!!GPH3DDESIGN1.view, !!CE.position)|
		
		para .logoButton at xmax.unclaimButton  ymin.unclaimButton - 0.18 pixmap wid 4 hei 1.9
